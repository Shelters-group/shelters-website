---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailCapture from '../components/EmailCapture.astro';

const segments = [
  {
    name: 'Premium',
    tagline: 'Accès sélectif à des opportunités curées.',
    ticket: 'À partir de 10 000 €',
  },
  {
    name: 'Club',
    tagline: 'Co-investissement entre pairs avec accompagnement dédié.',
    ticket: 'À partir de 100 000 €',
  },
  {
    name: 'Family Office',
    tagline: 'Structuration sur mesure et deal flow privé.',
    ticket: 'Sur devis',
  },
];
---

<BaseLayout title="Shelters — Investir autrement">
  <section class="hero">
    <p class="eyebrow">Plateforme d'investissement privée</p>
    <h1>Investir, autrement.</h1>
    <p class="lede">
      Shelters donne accès à un deal flow curé et segmenté, pour investisseurs
      qualifiés. Trois niveaux d'accompagnement : Premium, Club, Family Office.
    </p>

    <EmailCapture />

    <p class="hero-note">
      Inscription sur invitation après validation KYC.
    </p>
  </section>

  <section class="segments">
    <h2>Trois façons d'accéder aux opportunités</h2>
    <div class="segment-grid">
      {
        segments.map((s) => (
          <article class="segment-card">
            <h3>{s.name}</h3>
            <p class="tagline">{s.tagline}</p>
            <p class="ticket">{s.ticket}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    max-width: var(--max);
    margin: 0 auto;
    padding: 4rem 1.25rem 3rem;
  }

  .eyebrow {
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.75rem;
    margin: 0 0 0.75rem;
  }

  .hero h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    line-height: 1.1;
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .lede {
    font-size: 1.125rem;
    color: var(--muted);
    max-width: 640px;
    margin: 0 0 1.5rem;
  }

  .hero-note {
    font-size: 0.8125rem;
    color: var(--muted);
    margin: 1rem 0 0;
  }

  .segments {
    max-width: var(--max);
    margin: 0 auto;
    padding: 3rem 1.25rem 5rem;
  }

  .segments h2 {
    font-size: 1.5rem;
    margin: 0 0 1.5rem;
  }

  .segment-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }

  .segment-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
  }

  .segment-card h3 {
    margin: 0 0 0.5rem;
    color: var(--accent);
    letter-spacing: 0.04em;
  }

  .tagline {
    color: var(--fg);
    margin: 0 0 1rem;
  }

  .ticket {
    color: var(--muted);
    font-size: 0.875rem;
    margin: 0;
  }
</style>
